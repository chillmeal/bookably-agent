# Telegram
TG_BOT_TOKEN=123456:ABC-DEF
TG_WEBHOOK_URL=https://app.bookably.ru/bot/webhook
TG_WEBHOOK_SECRET=replace-with-random-secret

# Redis (compose default)
REDIS_URL=redis://redis:6379/0

# ACP
ACP_BASE_URL=http://acp:8080
ACP_API_KEY=replace-with-strong-key

# Bookably
BOOKABLY_API_URL=https://app.bookably.ru
BOOKABLY_BOT_SERVICE_KEY=replace-with-shared-service-key

# LLM (OpenRouter strict model policy)
LLM_PROVIDER=openrouter
LLM_API_KEY=replace-with-openrouter-token
LLM_MODEL=openai/gpt-5.4-nano

# Mini App
MINI_APP_URL=https://app.bookably.ru

# Server
PORT=8080
LOG_LEVEL=info

# Timeouts / TTLs
LLM_TIMEOUT=15s
SESSION_TTL=24h
PLAN_TTL=15m
WORKER_TIMEOUT=90s
ACP_POLL_INTERVAL=2s
ACP_POLL_TIMEOUT=30s
BOOKABLY_HTTP_TIMEOUT=5s
