# Telegram
TG_BOT_TOKEN=123456:ABC-DEF
TG_WEBHOOK_URL=https://your-ngrok.ngrok.io/webhook
TG_WEBHOOK_SECRET=replace-with-random-secret

# Redis
REDIS_URL=redis://localhost:6379/0

# ACP
ACP_BASE_URL=http://localhost:8181
ACP_API_KEY=local-acp-key

# Bookably
BOOKABLY_API_URL=http://localhost:3000
BOOKABLY_SPECIALIST_ID=spec-1

# LLM
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=

# Mini App
MINI_APP_URL=https://t.me/your_bot/app

# Server
PORT=8080
LOG_LEVEL=info

# Timeouts / TTLs
LLM_TIMEOUT=15s
SESSION_TTL=24h
PLAN_TTL=15m
ACP_POLL_INTERVAL=2s
ACP_POLL_TIMEOUT=30s
BOOKABLY_HTTP_TIMEOUT=5s
